# OpenCode server
OPENCODE_BASE_URL=http://127.0.0.1:4096
# OPENCODE_SERVER_USERNAME=opencode
# OPENCODE_SERVER_PASSWORD=
# OPENCODE_TIMEOUT_MS=120000

# NextAuth / GitHub OAuth (required for sign-in)
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_GITHUB_ID=your-github-oauth-app-client-id
AUTH_GITHUB_SECRET=your-github-oauth-app-client-secret
# Required for localhost in dev (Auth.js UntrustedHost)
AUTH_TRUST_HOST=true

# Directory where cloned repos are stored (default: OS temp dir)
# OPENVIBE_REPOS_DIR=/tmp/openvibe-repos
